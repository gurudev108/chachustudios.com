#!/bin/bash
# Shortcut for ChachuStudios morning stream utility.
#
# Examples:
#   ./cs-live
#   ./cs-live --run
#   ./cs-live --test
#   ./cs-live --list

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_SCRIPT="$SCRIPT_DIR/chachustudios-morning-stream.sh"

HAS_RUN=false
HAS_TEST=false
ARGS=()

for arg in "$@"; do
  case "$arg" in
    --run)
      HAS_RUN=true
      ARGS+=("$arg")
      ;;
    --test)
      HAS_TEST=true
      ;;
    *)
      ARGS+=("$arg")
      ;;
  esac
done

if [ "$HAS_TEST" = true ]; then
  # Force dry-run in test mode.
  "$TARGET_SCRIPT" "${ARGS[@]}"
else
  # Default mode is live streaming.
  if [ "$HAS_RUN" = false ]; then
    ARGS+=("--run")
  fi
  "$TARGET_SCRIPT" "${ARGS[@]}"
fi
